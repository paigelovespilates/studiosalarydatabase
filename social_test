<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --olive: #373930;
  --linen: #EDEBE4;
  --olive-muted: rgba(237,235,228,0.45);
  --linen-muted: rgba(237,235,228,0.45);
  --olive-mid: rgba(237,235,228,0.72);
  --linen-mid: rgba(237,235,228,0.72);
